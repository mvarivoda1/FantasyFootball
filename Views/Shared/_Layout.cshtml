<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FantasyFootball</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="ff-navbar navbar navbar-expand-lg">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-trophy-fill"></i> FantasyFootball
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                        aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door"></i> Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Player" asp-action="Index">
                                <i class="bi bi-people"></i> Players
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="FantasyTeam" asp-action="Index">
                                <i class="bi bi-shield"></i> Teams
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="League" asp-action="Index">
                                <i class="bi bi-diagram-3"></i> Leagues
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Gameweek" asp-action="Index">
                                <i class="bi bi-calendar-week"></i> Gameweeks
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Transfer" asp-action="Index">
                                <i class="bi bi-arrow-left-right"></i> Transfers
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="ff-main">
            @RenderBody()
        </main>
    </div>

    <footer class="ff-footer">
        <div class="container d-flex justify-content-between align-items-center flex-wrap">
            <span>&copy; 2026 FantasyFootball</span>
            <span>Built with <i class="bi bi-heart-fill" style="color: var(--ff-accent);"></i> ASP.NET Core</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
